# KeelStack UI Starter — Environment
# Copy to .env.local: cp .env.local.example .env.local

# ── Required ──────────────────────────────────────────────────
# Server-side URL of the KeelStack Engine.
# Engine runs on 3000 by default. UI runs on 3001 (see package.json).
# Browser requests are proxied through Next.js — no CORS headers needed.
KEELSTACK_API_URL=http://localhost:3000

# ── LLM display config (mirrors engine .env — read-only for UI) ──
# Used only to display config info in the AI Usage dashboard.
# Not secrets. Do not put OPENAI_API_KEY here.
NEXT_PUBLIC_LLM_PROVIDER=stub
NEXT_PUBLIC_LLM_MODEL=gpt-4o-mini
NEXT_PUBLIC_LLM_MAX_TOKENS=1024
NEXT_PUBLIC_LLM_TOKEN_BUDGET_PER_HOUR=10000
NEXT_PUBLIC_LLM_TIMEOUT_MS=30000
